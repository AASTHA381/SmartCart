# Copy this file to `.env` and fill in your key. Never commit `.env`.

# Your free Groq API key — stays on the server, never sent to the browser.
# Get one free (no card) at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (optional). Free, fast options on Groq:
#   llama-3.3-70b-versatile  (best reasoning)
#   llama-3.1-8b-instant     (fastest)
GROQ_MODEL=llama-3.3-70b-versatile

# Port the server listens on (optional).
PORT=8787
